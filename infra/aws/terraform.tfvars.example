aws_region  = "us-east-1"
project     = "timemanager"
environment = "staging"

# Required: your apex domain (Route 53 zone should already exist).
domain_name    = "example.com"
hosted_zone_id = "Z0123456789ABCDEFGHIJ"

# Optional OAuth secrets (merged into Secrets Manager JSON).
# oauth_secrets = {
#   GOOGLE_CLIENT_ID     = "..."
#   GOOGLE_CLIENT_SECRET = "..."
#   GITHUB_CLIENT_ID     = "..."
#   GITHUB_CLIENT_SECRET = "..."
# }

supertokens_connection_uri = "https://try.supertokens.com"
db_instance_class          = "db.t4g.micro"
# Keep 0 until ECR images exist; then set to 1 and re-apply (or use deploy-apis.sh).
desired_count = 0

# Monthly cost budget (USD). At 100% actual spend, SNS emails you and the
# kill-switch Lambda hibernates the stack (same path as `nx run timemanager-aws:down`).
monthly_budget_amount = 50
budget_alert_email    = "you@example.com"

# GitHub Actions OIDC deploy role (push to staging → deploy-apis/deploy-web).
# github_repository = "DanEscamilla/timemanager"
# create_github_oidc_provider = true  # set false if the OIDC provider already exists in the account
