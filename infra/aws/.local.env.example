# Copy to infra/aws/.local.env (gitignored) and adjust.
# Loaded automatically by deploy-apis.sh, deploy-web.sh, check-health.sh,
# ecs-shell.sh, infra-down.sh, and infra-up.sh.
# Inline env vars always win over values in this file.

DOMAIN=example.com
AWS_REGION=us-east-1

# Optional overrides
# ECS_CLUSTER=timemanager-staging
# AUTH_TAG=latest
# API_TAG=latest
# AUTH_API_BASE_URL=https://auth.example.com
# API_BASE_URL=https://api.example.com
# SPENDMANAGER_API_BASE_URL=https://spend-api.example.com
# FCM_VAPID_KEY=
# SPENDMANAGER_FCM_VAPID_KEY=
# VITE_API_DOMAIN=https://auth.example.com
# VITE_WEBSITE_DOMAIN=https://account.example.com
# TIMEOUT=10
