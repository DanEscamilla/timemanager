{
  "name": "timemanager-aws",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "tags": ["scope:timemanager", "type:infra"],
  "targets": {
    "init": {
      "executor": "nx:run-commands",
      "options": {
        "command": "terraform init",
        "cwd": "infra/aws"
      }
    },
    "plan": {
      "executor": "nx:run-commands",
      "options": {
        "command": "terraform plan",
        "cwd": "infra/aws"
      }
    },
    "apply": {
      "executor": "nx:run-commands",
      "options": {
        "command": "terraform apply",
        "cwd": "infra/aws"
      }
    },
    "deploy-apis": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./infra/aws/scripts/deploy-apis.sh",
        "cwd": "{workspaceRoot}"
      }
    },
    "deploy-web": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./infra/aws/scripts/deploy-web.sh",
        "cwd": "{workspaceRoot}"
      }
    },
    "health": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./infra/aws/scripts/check-health.sh",
        "cwd": "{workspaceRoot}"
      }
    },
    "ecs-shell": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./infra/aws/scripts/ecs-shell.sh",
        "cwd": "{workspaceRoot}"
      }
    },
    "down": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./infra/aws/scripts/infra-down.sh",
        "cwd": "{workspaceRoot}"
      }
    },
    "up": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./infra/aws/scripts/infra-up.sh",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
