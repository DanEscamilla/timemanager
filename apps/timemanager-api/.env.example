# Postgres (local defaults match infra/timemanager-db)
# Prefer DATABASE_URL in cloud; otherwise PG* vars.
# Local (no TLS): postgres://postgres:test1234@localhost:5432/timemanager
# RDS: append ?sslmode=require (Terraform does this in Secrets Manager).
# DATABASE_URL=postgres://postgres:test1234@localhost:5432/timemanager
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=test1234
PGDATABASE=timemanager

# SuperTokens JWKS source (user-manager-api)
AUTH_API_DOMAIN=http://localhost:3001

# Firebase Cloud Messaging (optional — unset = no-op push sender)
# Prefer JSON string in cloud; path is convenient for local files (gitignored).
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
