{
  "name": "mailbox-worker",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/mailbox-worker/src",
  "tags": ["scope:mailbox", "type:api", "runtime:deno"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "continuous": true,
      "dependsOn": ["mailbox-api:migrate"],
      "options": {
        "command": "deno task dev",
        "cwd": "apps/mailbox-worker"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "deno task test",
        "cwd": "apps/mailbox-worker"
      }
    }
  }
}
