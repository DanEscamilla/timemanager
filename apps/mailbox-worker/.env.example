# Same Postgres DB as mailbox-api
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=test1234
PGDATABASE=mailbox

# Poll interval in milliseconds (default 5 minutes)
POLL_INTERVAL_MS=300000

# AI gateway (classify + template generation for unmatched emails)
AI_API_BASE_URL=http://localhost:3004
AI_SERVICE_KEY=dev-ai-service-key

# Gmail OAuth client (token refresh — same Web client as mailbox-api)
# GMAIL_OAUTH_CLIENT_ID=
# GMAIL_OAUTH_CLIENT_SECRET=
