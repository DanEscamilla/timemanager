{
  "imports": {
    "kysely": "npm:kysely@^0.28.1",
    "pg": "npm:pg@^8.11.3",
    "@types/pg": "npm:@types/pg@^8.10.9",
    "deno_api_kit/": "../../libs/deno_api_kit/",
    "mailbox_kit/": "../../libs/mailbox_kit/",
    "mailbox_api/": "../mailbox-api/src/"
  },
  "tasks": {
    "dev": "deno run --allow-net --allow-env --allow-read --allow-sys --watch src/main.ts",
    "start": "deno run --allow-net --allow-env --allow-read --allow-sys src/main.ts",
    "sync-once": "deno run --allow-net --allow-env --allow-read --allow-sys src/sync_once.ts",
    "test": "deno test --allow-env --allow-read --allow-net --allow-sys src"
  },
  "compilerOptions": {
    "lib": ["deno.window"],
    "strict": true
  },
  "nodeModulesDir": "auto"
}
