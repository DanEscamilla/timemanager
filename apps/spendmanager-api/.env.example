# Postgres (local defaults match infra/timemanager-db, DB name spendmanager)
# Prefer DATABASE_URL in cloud; otherwise PG* vars.
# Local (no TLS): postgres://postgres:test1234@localhost:5432/spendmanager
# DATABASE_URL=postgres://postgres:test1234@localhost:5432/spendmanager
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=test1234
PGDATABASE=spendmanager

# SuperTokens JWKS source (user-manager-api)
AUTH_API_DOMAIN=http://localhost:3001

# GraphQL listen port
PORT=3002

# Firebase Cloud Messaging (optional — unset = no-op push sender)
# Prefer JSON string in cloud; path is convenient for local files (gitignored).
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
