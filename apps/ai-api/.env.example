PORT=3004

# development | production — enables request lifecycle logs when development/dev
AI_ENV=development

# Shared secret for backend callers (Authorization: Bearer … or X-AI-Service-Key)
AI_SERVICE_KEY=dev-ai-service-key

# Base URL for the interactive CLI (pnpm ai:cli); defaults to http://localhost:3004
# AI_API_BASE_URL=http://localhost:3004

# gemini (default) | openai_compatible
AI_PROVIDER=gemini

# Model tiers (omit to fall back to GEMINI_MODEL / AI_MODEL / provider default)
# Low: classify / cheap use cases; high: template generation
# AI_MODEL_LOW=gemini-2.0-flash
# AI_MODEL_HIGH=gemini-2.5-pro

# Gemini free tier (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Self-host / OpenAI-compatible (when AI_PROVIDER=openai_compatible)
# AI_BASE_URL=http://localhost:11434/v1
# AI_API_KEY=
# AI_MODEL=llama3.2
