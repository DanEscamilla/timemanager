# Postgres (local defaults match infra/timemanager-db, DB name mailbox)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=test1234
PGDATABASE=mailbox

# SuperTokens JWKS source (user-manager-api)
AUTH_API_DOMAIN=http://localhost:3001

# GraphQL listen port
PORT=3003

# Gmail OAuth (optional for fixture-only local use)
# Create a Google Cloud **Web** OAuth client; enable Gmail API.
# Authorized redirect URI must match GMAIL_OAUTH_REDIRECT_URI.
# GMAIL_OAUTH_CLIENT_ID=
# GMAIL_OAUTH_CLIENT_SECRET=
# GMAIL_OAUTH_REDIRECT_URI=http://localhost:3003/oauth/gmail/callback
# Comma-separated Flutter return URL origins/prefixes (open-redirect guard)
# GMAIL_OAUTH_RETURN_TO_ALLOWLIST=http://localhost:4445,spendmanager://settings/email-import

# AI gateway (template generation — same key as apps/ai-api)
AI_API_BASE_URL=http://localhost:3004
AI_SERVICE_KEY=dev-ai-service-key

# spendmanager GraphQL (accept → createExpense, JWT forwarded)
SPENDMANAGER_API_BASE_URL=http://localhost:3002
