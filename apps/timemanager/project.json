{
  "name": "timemanager",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/timemanager/lib",
  "tags": ["scope:timemanager", "type:app", "runtime:flutter"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "continuous": true,
      "dependsOn": ["user-manager-api:serve"],
      "options": {
        "command": "flutter run -d chrome --web-port=4444",
        "cwd": "apps/timemanager"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "flutter test",
        "cwd": "apps/timemanager"
      }
    },
    "analyze": {
      "executor": "nx:run-commands",
      "options": {
        "command": "flutter analyze",
        "cwd": "apps/timemanager"
      }
    },
    "pub-get": {
      "executor": "nx:run-commands",
      "options": {
        "command": "flutter pub get",
        "cwd": "apps/timemanager"
      }
    },
    "build-web": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./scripts/with-cloud-apis.sh build web --release",
        "cwd": "apps/timemanager"
      }
    },
    "build-macos": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./scripts/with-cloud-apis.sh build macos --release",
        "cwd": "apps/timemanager"
      }
    },
    "build-ios": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./scripts/with-cloud-apis.sh build ios --release",
        "cwd": "apps/timemanager"
      }
    },
    "build-ipa": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./scripts/with-cloud-apis.sh build ipa --release",
        "cwd": "apps/timemanager"
      }
    },
    "build-apk": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./scripts/with-cloud-apis.sh build apk --release",
        "cwd": "apps/timemanager"
      }
    },
    "build-appbundle": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./scripts/with-cloud-apis.sh build appbundle --release",
        "cwd": "apps/timemanager"
      }
    },
    "build-linux": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./scripts/with-cloud-apis.sh build linux --release",
        "cwd": "apps/timemanager"
      }
    },
    "build-windows": {
      "executor": "nx:run-commands",
      "options": {
        "command": "./scripts/with-cloud-apis.sh build windows --release",
        "cwd": "apps/timemanager"
      }
    },
    "serve-cloud": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "./scripts/with-cloud-apis.sh run -d chrome --web-port=4444",
        "cwd": "apps/timemanager"
      }
    },
    "serve-cloud-macos": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "./scripts/with-cloud-apis.sh run -d macos",
        "cwd": "apps/timemanager"
      }
    }
  }
}
