{
  "name": "spendmanager",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/spendmanager/lib",
  "tags": ["scope:spendmanager", "type:app", "runtime:flutter"],
  "targets": {
    "serve": {
      "executor": "nx:run-commands",
      "continuous": true,
      "dependsOn": ["user-manager-api:serve"],
      "options": {
        "command": "flutter run -d chrome --web-port=4445",
        "cwd": "apps/spendmanager"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "flutter test",
        "cwd": "apps/spendmanager"
      }
    },
    "analyze": {
      "executor": "nx:run-commands",
      "options": {
        "command": "flutter analyze",
        "cwd": "apps/spendmanager"
      }
    },
    "pub-get": {
      "executor": "nx:run-commands",
      "options": {
        "command": "flutter pub get",
        "cwd": "apps/spendmanager"
      }
    }
  }
}
