{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "timemanager",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/apps/timemanager",
      "program": "${workspaceFolder}/apps/timemanager/lib/main.dart",
      "flutterMode": "debug",
      "toolArgs": ["--web-port=4444"]
    },
    {
      "name": "timemanager (macos)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/apps/timemanager",
      "program": "${workspaceFolder}/apps/timemanager/lib/main.dart",
      "flutterMode": "debug",
      "deviceId": "macos"
    },
    {
      "name": "timemanager (profile)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/apps/timemanager",
      "program": "${workspaceFolder}/apps/timemanager/lib/main.dart",
      "flutterMode": "profile",
      "deviceId": "chrome",
      "toolArgs": ["--web-port=4444"]
    },
    {
      "name": "timemanager (release)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/apps/timemanager",
      "program": "${workspaceFolder}/apps/timemanager/lib/main.dart",
      "flutterMode": "release",
      "deviceId": "chrome",
      "toolArgs": ["--web-port=4444"]
    },
    {
      "name": "timemanager (device, local)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/apps/timemanager",
      "program": "${workspaceFolder}/apps/timemanager/lib/main.dart",
      "flutterMode": "debug",
      "preLaunchTask": "update-local-dart-defines",
      "toolArgs": [
        "--dart-define-from-file=config/local.dart-defines.json"
      ]
    },
    {
      "name": "timemanager (device, cloud)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/apps/timemanager",
      "program": "${workspaceFolder}/apps/timemanager/lib/main.dart",
      "flutterMode": "debug",
      "toolArgs": [
        "--dart-define-from-file=config/cloud.dart-defines.json"
      ]
    },
    {
      "name": "spendmanager",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/apps/spendmanager",
      "program": "${workspaceFolder}/apps/spendmanager/lib/main.dart",
      "flutterMode": "debug",
      "toolArgs": [
        "--web-port=4445",
        "--dart-define-from-file=config/local.dart-defines.json"
      ]
    },
    {
      "name": "spendmanager (macos)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/apps/spendmanager",
      "program": "${workspaceFolder}/apps/spendmanager/lib/main.dart",
      "flutterMode": "debug",
      "deviceId": "macos",
      "toolArgs": [
        "--dart-define-from-file=config/local.dart-defines.json"
      ]
    },
    {
      "name": "spendmanager (device, local)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/apps/spendmanager",
      "program": "${workspaceFolder}/apps/spendmanager/lib/main.dart",
      "flutterMode": "debug",
      "preLaunchTask": "update-local-dart-defines",
      "toolArgs": [
        "--dart-define-from-file=config/local.dart-defines.json"
      ]
    },
    {
      "name": "spendmanager (device, cloud)",
      "request": "launch",
      "type": "dart",
      "cwd": "${workspaceFolder}/apps/spendmanager",
      "program": "${workspaceFolder}/apps/spendmanager/lib/main.dart",
      "flutterMode": "debug",
      "toolArgs": [
        "--dart-define-from-file=config/cloud.dart-defines.json"
      ]
    }
  ]
}
