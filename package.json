{
  "name": "@timemanager/source",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.34.5",
  "scripts": {
    "serve": "nx run-many -t serve -p user-manager-api,ai-api,mailbox-api,mailbox-worker,timemanager-api,spendmanager-api,timemanager,spendmanager",
    "services": "nx run-many -t serve -p user-manager-api,ai-api,mailbox-api,mailbox-worker",
    "timemanager": "./scripts/ensure-dev-services.sh timemanager-api timemanager",
    "spendmanager": "./scripts/ensure-dev-services.sh spendmanager-api spendmanager",
    "mailbox": "./scripts/ensure-dev-services.sh mailbox-api mailbox-worker",
    "ai": "nx serve ai-api",
    "ai:cli": "nx run ai-api:cli",
    "user-manager": "nx run-many -t serve -p user-manager-web,user-manager-api",
    "db:up": "nx run timemanager-api:migrate",
    "db:down": "nx run timemanager-db:down"
  },
  "devDependencies": {
    "@nx/js": "^23.0.1"
  }
}
